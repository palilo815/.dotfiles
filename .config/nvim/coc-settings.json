{
    "languageserver": {
      "ccls": {
        "command": "ccls",
        "filetypes": ["c", "cc", "cpp"],
        "rootPatterns": [".ccls", "compile_commands.json", ".git/", ".hg/"],
        "initializationOptions": {
            "cache": {
              "directory": "/tmp/ccls"
            }
          }
      },
      "rust": {
        "command": "rust-analyzer",
        "filetypes": ["rs, rust"],
        "rootPatterns": ["Cargo.toml"]
      }
    },
}
